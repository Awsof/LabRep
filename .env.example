# ─────────────────────────────────────────────────────────────
# LabRep — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git.
# ─────────────────────────────────────────────────────────────

# ── TursoDB (libSQL) ─────────────────────────────────────────
# Criar com: turso db create labrep-prod
# URL com: turso db show labrep-prod --url
# Token com: turso db tokens create labrep-prod
TURSO_DATABASE_URL=libsql://labrep-prod-[seu-usuario].turso.io
TURSO_AUTH_TOKEN=

# ── Clerk Auth ───────────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com/
# A publishable key é segura para o frontend (começa com pk_)
CLERK_PUBLISHABLE_KEY=pk_test_51TedqKALOIEa04vtAm7Wie24SDTAoNxsN4LBHL1LJmBTjbDlhiKRmUVnTD7Vqenek2ShWV4FB6KujqQ7ZAuzhpL900x0PEUrIo
# A secret key NUNCA vai para o frontend (começa com sk_)
CLERK_SECRET_KEY=sk_test_

# ── Stripe ───────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_51TedqKALOIEa04vtAm7Wie24SDTAoNxsN4LBHL1LJmBTjbDlhiKRmUVnTD7Vqenek2ShWV4FB6KujqQ7ZAuzhpL900x0PEUrIo
STRIPE_SECRET_KEY=sk_test_
# Obtido após criar o webhook em: Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Preços criados no Dashboard Stripe (Products → Add Product)
STRIPE_PRICE_PRO=price_        # R$79/mês — Plano Pro
STRIPE_PRICE_PRO_PLUS=price_   # R$149/mês — Plano Pro+
STRIPE_PRICE_B2B=price_        # R$1.200/mês — Plano B2B

# ── Resend (Email transacional) ──────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@labrep.com.br

# ── Cron Job (Vercel Cron) ───────────────────────────────────
# String aleatória segura — usada para autenticar o cron job
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV=development
